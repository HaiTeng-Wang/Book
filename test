    1. 基础验证 - Email 格式验证
        ```swift
        @propertyWrapper
        struct EmailValidation {
            private var value: String = ""
            private var isValid = false
            
            var wrappedValue: String {
                get { value }
                set {
                    isValid = newValue.contains("@") && newValue.contains(".")
                    value = newValue
                }
            }
            
            var projectedValue: Bool {  // 通过$符号访问
                return isValid
            }
        }

        struct UserRegistration {
            @EmailValidation var email: String
            
            func validateForm() {
                if $email {  // 通过$email访问isValid
                    print("邮箱格式正确")
                } else {
                    print("邮箱格式错误")
                }
            }
        }
        ```
    2. 基础验证 - 带验证的包装器（通过闭包初始化属性包装器，来验证属性是否符合某一特定格式）
        ```swift
        @propertyWrapper
        struct Validated<T> {
            private var value: T
            private let validation: (T) -> Bool
            
            var wrappedValue: T {
                get { value }
                set {
                    if validation(newValue) {
                        value = newValue
                    } else {
                        print("⚠️ 验证失败: \(newValue) 不符合条件")
                    }
                }
            }
            
            init(wrappedValue: T, _ validation: @escaping (T) -> Bool) {
                self.validation = validation
                self.value = wrappedValue
            }
        }

        // 使用示例
        struct Person {
            @Validated({ $0 >= 0 && $0 <= 150 }) var age: Int = 0
            @Validated({ $0.count >= 2 && $0.count <= 50 }) var name: String = ""
            @Validated({ $0.contains("@") }) var email: String = ""
        }

        var person = Person()
        person.age = 200      // ⚠️ 验证失败
        person.name = "A"     // ⚠️ 验证失败
        person.email = "abc"  // ⚠️ 验证失败

        person.age = 25
        person.name = "张三"
        person.email = "zhangsan@example.com"
        print(person.age)    // 25
        ```
    3. 数据处理 - 字符创处理包装器（去除字符串首尾空格）
        ```swift
        @propertyWrapper
        struct Trimmed {
            private var value: String = ""
            
            var wrappedValue: String {
                get { value }
                set { value = newValue.trimmingCharacters(in: .whitespacesAndNewlines) }
            }
            
            init(wrappedValue: String) {
                self.wrappedValue = wrappedValue
            }
        }

        // 使用场景：用户输入、表单数据
        struct UserInput {
            @Trimmed var username: String
            @Trimmed var email: String
            @Trimmed var bio: String
        }

        let input = UserInput(
            username: "  john_doe  ",
            email: "  john@example.com  ",
            bio: "  Hello World  "
        )
        print(input.username) // "john_doe"
        ```
    4. 数据转换与格式化 - @Formatted，自动格式化字符串（如日期、货币）。
        ```swift
        @propertyWrapper
        struct Formatted {
            private var storage: Date
            private let formatter: DateFormatter

            var wrappedValue: String {
                formatter.string(from: storage)
            }

            init(wrappedValue: Date, format: String) {
                self.storage = wrappedValue
                self.formatter = DateFormatter()
                self.formatter.dateFormat = format
            }
        }

        // 使用
        struct EventView {
            @Formatted(format: "yyyy-MM-dd") var date: Date = Date()
        }
        ```
    5. 本地化字符串
        ```swift
        @propertyWrapper
        struct Localized {
            private let key: String
            var wrappedValue: String {
                NSLocalizedString(key, comment: "")
            }

            init(_ key: String) {
                self.key = key
            }
        }

        // 使用
        struct ContentView {
            @Localized("welcome_message") var title: String
        }
        ```

